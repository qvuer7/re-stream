# re-stream config. Copy to .env and edit:   cp .env.example .env
#
# Two kinds of variables:
#   *_PORT  -> host ports, read by docker-compose
#   MTX_*   -> passed straight into MediaMTX as native config
# MediaMTX key reference:
#   https://github.com/bluenviron/mediamtx/blob/main/mediamtx.yml
#
# NOTE: no inline comments after a value (env_file does not strip them).

# host ports
RTMP_PORT=1935
HLS_PORT=8888
WHEP_PORT=8889
WEBRTC_UDP_PORT=8189
API_PORT=9997

# MediaMTX behaviour (every MTX_* below is native MediaMTX config)
# enable the control API (add_cam.py uses it)
MTX_API=yes
# low-latency HLS (~1-2s)
MTX_HLSVARIANT=lowLatency
# IP browsers connect to for WebRTC; set your LAN/public IP when off localhost
MTX_WEBRTCADDITIONALHOSTS=127.0.0.1

# auth: one open "any" user with all permissions = no auth (fine for a local box
# or relaying public cams). MediaMTX's default user lacks the "api" permission, so
# these lines are what let add_cam.py reach the control API. To LOCK it down, set a
# pass and split into publish-only / read-only users (see MediaMTX auth docs).
MTX_AUTHINTERNALUSERS_0_USER=any
MTX_AUTHINTERNALUSERS_0_PASS=
MTX_AUTHINTERNALUSERS_0_PERMISSIONS_0_ACTION=read
MTX_AUTHINTERNALUSERS_0_PERMISSIONS_1_ACTION=publish
MTX_AUTHINTERNALUSERS_0_PERMISSIONS_2_ACTION=playback
MTX_AUTHINTERNALUSERS_0_PERMISSIONS_3_ACTION=api
MTX_AUTHINTERNALUSERS_0_PERMISSIONS_4_ACTION=metrics
